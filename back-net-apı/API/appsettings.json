{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "your-connection-string"
  },
  "CORS": {
    "Origin": [
      "http://localhost:5173",
      "http://192.168.1.144:5173"
    ]
  },
  "SecurityKey": {
    "ApiKey": "your-security-key"
  },
  "OpenAIKey": {
    "AIKey": "your-api-key"
  },
  "SerilogCORS": {
    "ElasticUrl": "http://localhost:9200",
    "DataStream": "aichatcore-logs"
  }
}
